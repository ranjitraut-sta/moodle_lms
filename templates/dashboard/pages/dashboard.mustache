<div class="row g-4 mt-4">
    <div class="col-12 col-sm-6 col-md-6 col-xl-4">
        <div class="amd-lms-user-dash-card amd-lms-user-dash-stat-card-courses">
            <div class="amd-lms-user-dash-card-body">
                <p>Courses</p>
                <h3>{{completed_courses_count}}/{{enrolled_courses_count}}</h3>
                <p class="mb-0 mt-2">Completed</p>
                <i class="fa fa-book amd-lms-user-dash-stat-icon" aria-hidden="true"></i>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-md-6 col-xl-4">
        <div class="amd-lms-user-dash-card amd-lms-user-dash-stat-card-leaderboard">
            <div class="amd-lms-user-dash-card-body">
                <p>Pending Assignments</p>
                <h3>{{pending_assignments}}</h3>
                <p class="mb-0">To be submitted</p>
                <i class="fa fa-tasks amd-lms-user-dash-stat-icon" aria-hidden="true"></i>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-md-6 col-xl-4">
        <div class="amd-lms-user-dash-card amd-lms-user-dash-stat-card-attendance">
            <div class="amd-lms-user-dash-card-body">
                <p>Total Certificates</p>
                <h3>{{total_certificates}}</h3>
                <p class="mb-0">Earned</p>
                <i class="fa fa-certificate amd-lms-user-dash-stat-icon" aria-hidden="true"></i>
            </div>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm p-3">
            <h6 class="fw-bold mb-3 small">Course Progress</h6>
            <div style="height: 250px;"><canvas id="courseChart"></canvas></div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 shadow-sm p-3">
            <h6 class="fw-bold mb-3 small">Weekly Activity</h6>
            <div style="height: 250px;"><canvas id="activityChart"></canvas></div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
// Wait for DOM to load
document.addEventListener('DOMContentLoaded', function() {
    
    // 1. Course Progress (Doughnut)
    const courseCtx = document.getElementById('courseChart').getContext('2d');
    new Chart(courseCtx, {
        type: 'doughnut',
        data: {
            labels: [{{#course_progress.labels}}"{{.}}",{{/course_progress.labels}}],
            datasets: [{
                data: [{{#course_progress.data}}{{.}},{{/course_progress.data}}],
                backgroundColor: ['#28a745', '#ffc107'],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom' } }
        }
    });


    // 3. Activity (Line)
    const activityCtx = document.getElementById('activityChart').getContext('2d');
    new Chart(activityCtx, {
        type: 'line',
        data: {
            labels: [{{#activity.labels}}"{{.}}",{{/activity.labels}}],
            datasets: [{
                label: 'Activity',
                data: [{{#activity.data}}{{.}},{{/activity.data}}],
                borderColor: '#6f42c1',
                backgroundColor: 'rgba(111, 66, 193, 0.1)',
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } }
        }
    });
});
</script>