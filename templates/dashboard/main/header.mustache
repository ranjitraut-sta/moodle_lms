<header class="amd-lms-user-dash-header d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center">
        <button class="btn d-lg-none me-3 p-0" id="amd-lms-mobile-toggle-btn">
            <i class="bi bi-list fs-3"></i>
        </button>
        <div>
            <h1 class="amd-lms-user-dash-greeting">Hello, {{user_firstname}}! 👋</h1>
            <p class="amd-lms-user-dash-subgreeting">Let's learn something new today!</p>
        </div>
    </div>
    <div class="d-flex align-items-center amd-lms-user-dash-header-icons">
        <i class="bi bi-search fs-5 me-3" id="amd-lms-search-open-btn" style="cursor:pointer"></i>
        <i class="bi bi-bell fs-5 me-3"></i>
        <i class="bi bi-chat-dots fs-5 me-4"></i>
        <div class="amd-lms-user-dash-profile d-flex align-items-center dropdown">
            <img src="{{user_picture_url}}" alt="User Avatar" class="rounded-circle me-2" style="width:40px; height:40px;">
            <div class="amd-lms-user-dash-profile-text d-none d-md-block" data-bs-toggle="dropdown">
                <strong>{{user_fullname}}</strong>
                <span>ID: {{user_id}}</span>
            </div>
            <a href="#" class="ms-auto ps-2" data-bs-toggle="dropdown">
                <i class="bi bi-chevron-down"></i>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 amd-lms-profile-menu">
                <li><a class="amd-dropdown-item d-flex align-items-center gap-2" href="{{profileurl}}"><i class="bi bi-person"></i> Profile</a></li>
                <li><a class="amd-dropdown-item d-flex align-items-center gap-2" href="#"><i class="bi bi-gear"></i> Settings</a></li>
                <li><hr class="dropdown-divider my-1"></li>
                <li><a class="amd-dropdown-item d-flex align-items-center gap-2 text-danger" href="{{logout_url}}"><i class="bi bi-box-arrow-right"></i> Logout</a></li>
            </ul>
        </div>
    </div>
</header>
