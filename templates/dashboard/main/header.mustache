

<header class="amd-lms-user-dash-header d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center">
        <button class="btn d-lg-none me-3 p-0" id="amd-lms-mobile-toggle-btn"><i class="bi bi-list fs-3"></i></button>
        <div>
            <h1 class="amd-lms-user-dash-greeting">Hello, {{user_firstname}}! 👋</h1>
            <p class="amd-lms-user-dash-subgreeting">Let's learn something new today!</p>
        </div>
    </div>
    <div class="d-flex align-items-center amd-lms-user-dash-header-icons">
        <div class="amd-lms-user-dash-profile d-flex align-items-center dropdown">

            <img src="https://i.pravatar.cc/40?u=aramide" alt="User Avatar" class="rounded-circle me-2">

            <div class="amd-lms-user-dash-profile-text d-none d-md-block">
                <strong>{{user_fullname}}</strong>
                <span>Student ID: {{user_id}}</span>
            </div>

            <!-- Toggle -->
            <button type="button" class="ms-auto ps-2 amd-dropdown-toggle">
                <i class="bi bi-chevron-down"></i>
            </button>

            <!-- Menu -->
            <ul class="dropdown-menu amd-dropdown-menu shadow-sm border-0 amd-lms-profile-menu">

                <li>
                    <a class="amd-dropdown-item d-flex align-items-center gap-2" href="user-dash-profile.html">
                        <i class="fas fa-user-circle text-primary"></i>
                        Profile
                    </a>
                </li>

                <li><hr class="dropdown-divider my-1"></li>

                <li>
                    <a class="amd-dropdown-item d-flex align-items-center gap-2 text-danger fw-semibold" href="{{logout_url}}">
                        <i class="fas fa-sign-out-alt"></i>
                        Logout
                    </a>
                </li>

            </ul>
        </div>

    </div>
</header>
<style>
.amd-dropdown-menu {
    display: none;
    position: absolute;
    right: 0;
    top: 100%;
    z-index: 9999;
}

.amd-dropdown-menu.show {
    display: block;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {

    // Toggle click
    document.querySelectorAll('.amd-dropdown-toggle').forEach(function(toggle) {
        toggle.addEventListener('click', function (e) {
            e.stopPropagation();

            let dropdown = this.closest('.dropdown');
            let menu = dropdown.querySelector('.amd-dropdown-menu');

            // Close all others
            document.querySelectorAll('.amd-dropdown-menu').forEach(function(m) {
                if (m !== menu) m.classList.remove('show');
            });

            // Toggle current
            menu.classList.toggle('show');
        });
    });

    // Click outside => close
    document.addEventListener('click', function () {
        document.querySelectorAll('.amd-dropdown-menu').forEach(function(menu) {
            menu.classList.remove('show');
        });
    });

});
</script>
