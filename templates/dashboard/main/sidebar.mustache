<nav class="amd-lms-user-dash-sidebar">
    <div>
        <div class="amd-lms-user-dash-sidebar-header">
            <div class="amd-lms-user-dash-logo">
                <span>LMS</span>
            </div>
            <button class="amd-lms-user-dash-sidebar-toggle d-lg-flex" id="amd-lms-desktop-toggle-btn">
                <i class="bi bi-chevron-left"></i>
            </button>
        </div>
        <ul class="amd-lms-user-dash-nav-list list-unstyled">
            {{#nav_main}}
            <li class="amd-lms-user-dash-nav-item {{#active}}active{{/active}}">
                <a href="{{url}}"><i class="bi {{icon}}"></i> <span>{{text}}</span>{{#badge}}<span class="badge rounded-pill">{{badge}}</span>{{/badge}}</a>
            </li>
            {{/nav_main}}
        </ul>
    </div>
    <ul class="amd-lms-user-dash-nav-list list-unstyled">
        {{#nav_footer}}
        <li class="amd-lms-user-dash-nav-item">
            <a href="{{url}}"><i class="bi {{icon}}"></i> <span>{{text}}</span></a>
        </li>
        {{/nav_footer}}
    </ul>
</nav>
