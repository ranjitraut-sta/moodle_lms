<!-- Preloader -->
<div class="amd-lms-hero-preloader d-none" id="preloader">
    <div class="preloader-text"> L Management S</div>
</div>

<header class="amd-lms-header" id="mainHeader">
    <div class="amd-lms-topbar d-none d-lg-flex justify-content-between align-items-center">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="amd-lms-topbar-social d-flex align-items-center gap-3">
                {{#setting.facebook}}<a href="{{{setting.facebook}}}" aria-label="Facebook" target="_blank" rel="noopener"><i class="fab fa-facebook-f"></i></a>{{/setting.facebook}}
                {{#setting.twitter}}<a href="{{{setting.twitter}}}" aria-label="Twitter" target="_blank" rel="noopener"><i class="fab fa-twitter"></i></a>{{/setting.twitter}}
                {{#setting.instagram}}<a href="{{{setting.instagram}}}" aria-label="Instagram" target="_blank" rel="noopener"><i class="fab fa-instagram"></i></a>{{/setting.instagram}}
                {{#setting.linkedin}}<a href="{{{setting.linkedin}}}" aria-label="LinkedIn" target="_blank" rel="noopener"><i class="fab fa-linkedin-in"></i></a>{{/setting.linkedin}}
            </div>
            <div class="d-flex align-items-center gap-3">
                {{#setting.isloggedin}}
                <a href="{{setting.wwwroot}}message/index.php" class="text-dark" title="Messages"><i class="bi bi-chat-dots fs-5"></i></a>
                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center gap-2 text-decoration-none dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="{{setting.useravatar}}" class="rounded-circle border" width="32" height="32" alt="avatar">
                        <span class="d-none d-lg-inline fw-semibold small">{{setting.userfullname}}</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow" style="min-width: 220px;">
                        <li class="px-3 py-2">
                            <div class="d-flex align-items-center gap-2">
                                <img src="{{setting.useravatar}}" class="rounded-circle" width="40" height="40">
                                <div class="fw-bold small">{{setting.userfullname}}</div>
                            </div>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="{{setting.dashboardurl}}"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                        <li><a class="dropdown-item" href="{{setting.profileurl}}"><i class="bi bi-person me-2"></i>Profile</a></li>
                        <li><a class="dropdown-item" href="{{setting.wwwroot}}message/index.php"><i class="bi bi-chat-dots me-2"></i>Messages</a></li>
                        {{#setting.mycourses}}
                        {{#-first}}<li><hr class="dropdown-divider"></li><li><h6 class="dropdown-header">My Courses</h6></li>{{/-first}}
                        <li><a class="dropdown-item small" href="{{url}}"><i class="bi bi-book me-2"></i>{{name}}</a></li>
                        {{/setting.mycourses}}
                        {{#setting.isadmin}}
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="{{setting.adminurl}}"><i class="bi bi-gear me-2"></i>Admin Panel</a></li>
                        {{/setting.isadmin}}
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="{{setting.logouturl}}"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                    </ul>
                </div>
                {{/setting.isloggedin}}
                {{^setting.isloggedin}}
                <a href="{{setting.loginurl}}" class="btn btn-sm amd-lms-btn-login">Login</a>
                {{/setting.isloggedin}}
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg amd-lms-navbar">
        <div class="container">
            <div class="amd-lms-main-nav-wrapper">
                <a class="navbar-brand amd-lms-brand" href="{{setting.wwwroot}}">
                    <img src="{{setting.logo}}" alt="Site Logo">
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span><i class="fa-solid fa-bars"></i></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav mx-auto amd-lms-nav">

                        {{#setting.custommenu}}
                        <li class="nav-item">
                            <a class="nav-link" href="{{url}}" {{#newtab}}target="_blank"{{/newtab}}>{{label}}</a>
                        </li>
                        {{/setting.custommenu}}

                        {{#setting.isloggedin}}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                My Courses
                            </a>
                            <ul class="dropdown-menu amd-lms-dropdown-menu">
                                {{#setting.mycourses}}
                                <li><a class="dropdown-item" href="{{url}}">{{name}}</a></li>
                                {{/setting.mycourses}}
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="{{setting.wwwroot}}course/index.php">All Courses</a></li>
                            </ul>
                        </li>
                        {{/setting.isloggedin}}

                        <li class="nav-item d-lg-none">
                            {{#setting.isloggedin}}
                            <a class="nav-link text-danger" href="{{setting.logouturl}}"><i class="bi bi-box-arrow-right me-1"></i>Logout</a>
                            {{/setting.isloggedin}}
                            {{^setting.isloggedin}}
                            <a class="nav-link" href="{{setting.loginurl}}">Login</a>
                            {{/setting.isloggedin}}
                        </li>

                    </ul>
                </div>
            </div>
        </div>
    </nav>
</header>
