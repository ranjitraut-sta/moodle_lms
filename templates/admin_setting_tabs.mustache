<div class="mytheme-settings-tabs">
    <ul class="nav nav-tabs mb-3" role="tablist">
        {{#tabs}}
        <li class="nav-item" role="presentation">
            <a class="nav-link {{#active}}active{{/active}}" 
               href="?section=themesettingmytheme&activetab={{name}}" 
               role="tab">
                {{displayname}}
            </a>
        </li>
        {{/tabs}}
    </ul>
    <div class="tab-content">
        {{#tabs}}
        <div class="tab-pane {{#active}}active show{{/active}}" role="tabpanel">
            {{{html}}}
        </div>
        {{/tabs}}
    </div>
</div>
