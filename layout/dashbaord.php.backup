<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LMS User Dashboard</title>

    <!-- Bootstrap CSS -->
    <link href="asset/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Google Fonts (Poppins) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="asset/css/user-dash.css">

</head>

<body>

    <div class="amd-lms-user-dash-main-wrapper">
        <!-- ================== Sidebar ================== -->
        <nav class="amd-lms-user-dash-sidebar">
            <div>
                <div class="amd-lms-user-dash-sidebar-header">
                    <div class="amd-lms-user-dash-logo">
                        <span>LMS</span>
                    </div>
                    <button class="amd-lms-user-dash-sidebar-toggle  d-lg-flex" id="amd-lms-desktop-toggle-btn">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                </div>
                <ul class="amd-lms-user-dash-nav-list list-unstyled">
                    <li class="amd-lms-user-dash-nav-item active"><a href="#"><i class="bi bi-grid-fill"></i>
                            <span>Dashboard</span></a></li>
                    <li class="amd-lms-user-dash-nav-item"><a href="user-course-list.html"><i
                                class="bi bi-calendar-week"></i>
                            <span> Course Lists</span></a></li>
                    <li class="amd-lms-user-dash-nav-item"><a href="user-course-list2.html"><i
                                class="bi bi-calendar-week"></i>
                            <span> Course Lists2</span></a></li>
                    <li class="amd-lms-user-dash-nav-item"><a href="#"><i class="bi bi-play-btn"></i>
                            <span>Classroom</span></a></li>
                    <li class="amd-lms-user-dash-nav-item"><a href="user-dash-message.html"><i
                                class="bi bi-chat-left-text"></i>
                            <span>Messages</span> <span class="badge rounded-pill">30</span></a></li>
                    <li class="amd-lms-user-dash-nav-item"><a href="#"><i class="bi bi-people"></i>
                            <span>Communities</span> <span class="badge rounded-pill">30</span></a></li>
                    <li class="amd-lms-user-dash-nav-item"><a href="user-dash-profile.html"><i class="bi bi-gear"></i>
                            <span>Settings</span></a></li>
                </ul>
            </div>
            <ul class="amd-lms-user-dash-nav-list list-unstyled">
                <li class="amd-lms-user-dash-nav-item"><a href="#"><i class="bi bi-question-circle"></i> <span>Help
                            Center</span></a></li>
                <li class="amd-lms-user-dash-nav-item"><a href="#"><i class="bi bi-box-arrow-right"></i>
                        <span>Logout</span></a></li>
            </ul>
        </nav>

        <div class="amd-lms-user-dash-main-container">
            <!-- ================== Header ================== -->
            <header class="amd-lms-user-dash-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <button class="btn d-lg-none me-3 p-0" id="amd-lms-mobile-toggle-btn"><i
                            class="bi bi-list fs-3"></i></button>
                    <div>
                        <h1 class="amd-lms-user-dash-greeting">Hello, Aramide! 👋</h1>
                        <p class="amd-lms-user-dash-subgreeting">Let's learn something new today!</p>
                    </div>
                </div>
                <div class="d-flex align-items-center amd-lms-user-dash-header-icons">
                    <i class="bi bi-search fs-5 me-3" id="amd-lms-search-open-btn"></i>
                    <i class="bi bi-bell fs-5 me-3"></i>
                    <i class="bi bi-chat-dots fs-5 me-4"></i>
                    <div class="amd-lms-user-dash-profile d-flex align-items-center dropdown">

                        <img src="https://i.pravatar.cc/40?u=aramide" alt="User Avatar" class="rounded-circle me-2">

                        <div class="amd-lms-user-dash-profile-text d-none d-md-block" data-bs-toggle="dropdown">
                            <strong>Aramide Adesanya</strong>
                            <span>Student ID: ALT/SOP/023/0195</span>
                        </div>

                        <!-- Dropdown toggle should be ONLY here -->
                        <a href="#" class="ms-auto ps-2" data-bs-toggle="dropdown">
                            <i class="bi bi-chevron-down"></i>
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 amd-lms-profile-menu">

                            <li>
                                <a class="amd-dropdown-item d-flex align-items-center gap-2"
                                    href="user-dash-profile.html">
                                    <i class="fas fa-user-circle text-primary"></i>
                                    Profile
                                </a>
                            </li>

                            <li>
                                <a class="amd-dropdown-item d-flex align-items-center gap-2"
                                    href="user-dash-profile.html">
                                    <i class="fas fa-cog text-warning"></i>
                                    Settings
                                </a>
                            </li>

                            <li>
                                <hr class="dropdown-divider my-1">
                            </li>

                            <li>
                                <a class=" amd-dropdown-item d-flex align-items-center gap-2 text-danger fw-semibold"
                                    href="../lms-landing-page/login.html">
                                    <i class="fas fa-sign-out-alt"></i>
                                    Logout
                                </a>
                            </li>

                        </ul>

                    </div>

                </div>
            </header>

            <!-- ================== Main Content ================== -->
            <main class="amd-lms-user-dash-main-content">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="amd-lms-user-dash-section-title">Dashboard</h2>
                    <button class="btn amd-lms-user-dash-folder-btn"><i class="bi bi-folder me-2"></i> Class
                        Folder</button>
                </div>

                <div class="row g-4">
                    <div class="col-12 col-sm-6 col-md-6 col-xl-3">

                        <div class="amd-lms-user-dash-card amd-lms-user-dash-stat-card-courses">
                            <div class="amd-lms-user-dash-card-body">
                                <p>Courses</p>
                                <h3>{{12/30}}</h3>
                                <p class="mb-0">Completed</p>
                                <img src="asset/imgs/Untitled design (13) (1).png" alt="books icon"
                                    class="amd-lms-user-dash-stat-icon">
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-sm-6 col-md-6 col-xl-3">

                        <div class="amd-lms-user-dash-card amd-lms-user-dash-stat-card-attendance">
                            <div class="amd-lms-user-dash-card-body">
                                <p>Class Attendance</p>
                                <h3>{{64}}<span class="fs-6 fw-normal"> points</span></h3>
                                <img src="asset/imgs/calendar-svgrepo-com (1).png" alt="calendar icon"
                                    class="amd-lms-user-dash-stat-icon">
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-sm-6 col-md-6 col-xl-3">

                        <div class="amd-lms-user-dash-card amd-lms-user-dash-stat-card-grade">
                            <div class="amd-lms-user-dash-card-body d-flex align-items-center">
                                <div>
                                    <p>Grade</p>
                                    <p class="mb-0 small">{{Your score is}}<br>{{Keep it up! 😉}}</p>
                                </div>
                                <div class="amd-lms-user-dash-grade-chart-container ms-auto">
                                    <svg class="amd-lms-user-dash-grade-chart" width="80" height="80"
                                        viewBox="0 0 36 36">
                                        <path class="amd-lms-user-dash-circle-bg"
                                            d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                        <path class="amd-lms-user-dash-circle" data-score="85" stroke-dasharray="0, 100"
                                            d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                        <text x="18" y="20.35" class="amd-lms-user-dash-percentage">{{85}}</text>
                                    </svg>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-sm-6 col-md-6 col-xl-3">

                        <div class="amd-lms-user-dash-card amd-lms-user-dash-stat-card-leaderboard">
                            <div class="amd-lms-user-dash-card-body">
                                <p>Leaderboard</p>
                                <h3>{{1st}}</h3>
                                <img src="asset/imgs/trophy-cup-svgrepo-com.png" alt="trophy icon"
                                    class="amd-lms-user-dash-stat-icon">
                            </div>
                        </div>
                    </div>
                </div>


                <div class="row g-4 mt-2">
                    <div class="col-lg-8">
                        <div class="amd-lms-user-dash-card">
                            <div class="amd-lms-user-dash-card-header">
                                <h3 class="amd-lms-user-dash-card-title">{{Upcoming Events}}</h3>
                            </div>
                            <div class="amd-lms-user-dash-card-body">

                                <div id="amd-lms-event-slider">
                                    <p class="text-primary fw-bold mb-2"><i class="bi bi-broadcast"></i> Live class</p>
                                    <div class="amd-lms-user-dash-event-item">
                                        <img src="https://images.unsplash.com/photo-1587620962725-abab7fe55159?w=500&amp;q=80"
                                            alt="Design System II">
                                        <div class="amd-lms-user-dash-event-info flex-grow-1">
                                            <h4>{{Design System II}}</h4>
                                            <p>{{by Ekemini Mark}}</p>
                                            <p><i class="bi bi-calendar-event"></i> {{25 July, 2024}} &nbsp; <i
                                                    class="bi bi-clock"></i> {{7:00 pm WAT}}</p>
                                            <div class="amd-lms-user-dash-event-controls">
                                                <button class="btn btn-primary px-4">{{Join Class}}</button>
                                                <div class="amd-lms-user-dash-event-slider-nav">
                                                    <a id="prev-event"><i class="bi bi-chevron-left"></i></a>
                                                    <span>1/4</span>
                                                    <a id="next-event"><i class="bi bi-chevron-right"></i></a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                        <div class="amd-lms-user-dash-card mt-4">
                            <div class="amd-lms-user-dash-card-header">
                                <h3 class="amd-lms-user-dash-card-title">{{Leadership Board}}</h3>
                            </div>
                            <div class="amd-lms-user-dash-card-body">
                                <div class="amd-lms-user-dash-leaderboard-header"><span>{{Rank}}</span><span>{{Student
                                        Name}}</span><span>{{Score}}</span></div>
                                <div class="amd-lms-user-dash-leaderboard-row current-user"><span>{{01}}</span><span>{{Aramide
                                        Adesanya (you) 🏆}}</span><span>{{100/100}}</span></div>
                                <div class="amd-lms-user-dash-leaderboard-row"><span>{{02}}</span><span>{{Chinedu
                                        Okeke}}</span><span>{{85/100}}</span></div>
                                <div class="amd-lms-user-dash-leaderboard-row"><span>{{03}}</span><span>{{Amina
                                        Yusuf}}</span><span>{{84/100}}</span></div>
                                <div class="amd-lms-user-dash-leaderboard-row"><span>{{04}}</span><span>{{Olufemi
                                        Adewale}}</span><span>{{75/100}}</span></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="amd-lms-user-dash-card">
                            <div
                                class="amd-lms-user-dash-card-header d-flex justify-content-between align-items-center">
                                <h3 class="amd-lms-user-dash-card-title">{{Assignments}}</h3><a href="#"
                                    class="text-decoration-none"
                                    style="font-size: 0.9rem; color: var(--amd-lms-primary-color)">{{View all}}</a>
                            </div>
                            <div class="amd-lms-user-dash-card-body">
                                <h4 class="h6 text-secondary fw-bold">{{To-do}}</h4>
                                <ul class="list-unstyled amd-lms-user-dash-assignment-list">
                                    <li><i class="bi bi-clock-history"></i>
                                        <div>
                                            <p>{{Capstone Project}}</p><small>{{Deadline}} &nbsp; {{16 Aug, 2024}} • {{3:00 pm
                                                WAT}}</small>
                                        </div>
                                    </li>
                                    <li><i class="bi bi-clock-history"></i>
                                        <div>
                                            <p>{{Design System Article}}</p><small>{{Deadline}} &nbsp; {{16 Aug, 2024}} • {{3:00 pm
                                                WAT}}</small>
                                        </div>
                                    </li>
                                </ul>
                                <h4 class="h6 text-secondary fw-bold mt-4">{{Completed}}</h4>
                                <ul class="list-unstyled amd-lms-user-dash-assignment-list">
                                    <li><i class="bi bi-check-circle-fill "></i>
                                        <div>
                                            <p>{{Designing for Use - The Heuristic Principles}}</p><small>{{Grade}}</small>
                                        </div><span class="ms-auto">{{96/100}}</span>
                                    </li>
                                    <li><i class="bi bi-check-circle-fill "></i>
                                        <div>
                                            <p>{{Problem Definition + Ideation}}</p><small>{{Grade}}</small>
                                        </div><span class="ms-auto">{{100/100}}</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        <div class="amd-lms-user-dash-card mt-4">
                            <div
                                class="amd-lms-user-dash-card-header d-flex justify-content-between align-items-center">
                                <h3 class="amd-lms-user-dash-card-title">{{Communities}}</h3><i class="bi bi-search"></i>
                            </div>
                            <div class="amd-lms-user-dash-card-body">
                                <ul class="list-unstyled amd-lms-user-dash-community-list">
                                    <li>{{LMS Africa Althub}} <i class="bi bi-three-dots"></i></li>
                                    <li>{{School of Product}} <i class="bi bi-three-dots"></i></li>
                                    <li>{{Direct Messages}} <i class="bi bi-three-dots"></i></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <div class="amd-lms-user-dash-mobile-overlay" id="amd-lms-mobile-overlay"></div>

    <div class="amd-lms-search-overlay" id="amd-lms-search-overlay">
        <div class="amd-lms-search-container">
            <button id="amd-lms-search-close-btn">&times;</button>
            <input type="search" id="amd-lms-search-input" placeholder="Search for courses, assignments, etc...">
        </div>
    </div>

    <script src="asset/scripts/bootstrap.bundle.min.js"></script>
    <script src="asset/scripts/user-dash.js"></script>

</body>

</html>

